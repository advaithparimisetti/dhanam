# Dhanaṁ backend — copy to .env and fill in. NEVER commit the real .env.

# App JWT secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
APP_JWT_SECRET=

# Firebase Admin — LOCAL dev: path to the service-account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./firebase-adminsdk.json

# Firebase Admin — PRODUCTION (Render): base64 of the service-account JSON.
# Generate: base64 -w0 firebase-adminsdk.json   (Windows: see Phase 5 notes)
FIREBASE_SERVICE_ACCOUNT_B64=

# Comma-separated allowed origins for CORS in production
# e.g. https://dhanam.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
