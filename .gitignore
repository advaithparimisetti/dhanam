# ============================================================================
# Dhanaṁ — root .gitignore (monorepo: /backend FastAPI, /frontend Vite)
# Secrets-first: nothing sensitive should ever reach the remote.
# ============================================================================

# ---- Secrets & credentials (NEVER COMMIT) ----
.env
.env.*
!.env.example
*.env
secrets/
# Firebase Admin service-account keys — any name, any location
*serviceAccount*.json
*service-account*.json
*firebase-adminsdk*.json
firebase-key*.json
*-adminsdk-*.json
google-credentials*.json
*.pem
*.key

# ---- Python / FastAPI backend ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.sqlite3

# ---- Node / Vite frontend ----
node_modules/
dist/
dist-ssr/
.vite/
*.local

# ---- Logs ----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- OS / Editor ----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.sw?
