rules_version = '2';

// Dhanaṁ — production Firestore security rules.
// Default-deny: anything not explicitly allowed below is rejected.
// Row-level security: a signed-in user can touch ONLY documents under their own UID.
service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Profile: user reads/writes only their own doc, and cannot spoof the uid field.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid)
                   && request.resource.data.uid == uid;
    }

    // Watchlist root doc + nested saved items: owner-only, top to bottom.
    match /watchlists/{uid} {
      allow read, write: if isOwner(uid);

      match /items/{ticker} {
        allow read, write: if isOwner(uid);
      }

      // Belt-and-suspenders: lock any future nested collections to the owner too.
      match /{document=**} {
        allow read, write: if isOwner(uid);
      }
    }

    // Everything else is denied by default (no catch-all allow).
  }
}
